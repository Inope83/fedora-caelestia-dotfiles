#!/bin/bash
# Update foot terminal colors from current.conf (tanpa restart paksa)

FOOT_CONFIG="$HOME/.config/foot/foot.ini"
SCHEME="$HOME/.config/hypr/scheme/current.conf"

# Ambil warna dari current.conf
BACKGROUND=$(grep '^\$background' "$SCHEME" | awk '{print $3}')
FOREGROUND=$(grep '^\$foreground' "$SCHEME" | awk '{print $3}')
TERM0=$(grep '^\$term0' "$SCHEME" | awk '{print $3}')
TERM1=$(grep '^\$term1' "$SCHEME" | awk '{print $3}')
TERM2=$(grep '^\$term2' "$SCHEME" | awk '{print $3}')
TERM3=$(grep '^\$term3' "$SCHEME" | awk '{print $3}')
TERM4=$(grep '^\$term4' "$SCHEME" | awk '{print $3}')
TERM5=$(grep '^\$term5' "$SCHEME" | awk '{print $3}')
TERM6=$(grep '^\$term6' "$SCHEME" | awk '{print $3}')
TERM7=$(grep '^\$term7' "$SCHEME" | awk '{print $3}')
TERM8=$(grep '^\$term8' "$SCHEME" | awk '{print $3}')
TERM9=$(grep '^\$term9' "$SCHEME" | awk '{print $3}')
TERM10=$(grep '^\$term10' "$SCHEME" | awk '{print $3}')
TERM11=$(grep '^\$term11' "$SCHEME" | awk '{print $3}')
TERM12=$(grep '^\$term12' "$SCHEME" | awk '{print $3}')
TERM13=$(grep '^\$term13' "$SCHEME" | awk '{print $3}')
TERM14=$(grep '^\$term14' "$SCHEME" | awk '{print $3}')
TERM15=$(grep '^\$term15' "$SCHEME" | awk '{print $3}')

# Default jika tidak ada
BACKGROUND=${BACKGROUND:-"131317"}
FOREGROUND=${FOREGROUND:-"e5e1e7"}
TERM0=${TERM0:-"353434"}
TERM1=${TERM1:-"ac73ff"}
TERM2=${TERM2:-"44def5"}
TERM3=${TERM3:-"ffdcf2"}
TERM4=${TERM4:-"99aad8"}
TERM5=${TERM5:-"b49fea"}
TERM6=${TERM6:-"9dceff"}
TERM7=${TERM7:-"e8d3de"}
TERM8=${TERM8:-"ac9fa9"}
TERM9=${TERM9:-"c093ff"}
TERM10=${TERM10:-"89ecff"}
TERM11=${TERM11:-"fff0f6"}
TERM12=${TERM12:-"b5c1dd"}
TERM13=${TERM13:-"c9b5f4"}
TERM14=${TERM14:-"bae0ff"}
TERM15=${TERM15:-"ffffff"}

# Update file foot.ini (tanpa restart paksa)
sed -i "/^\[colors\]/,/^\[/ {
    s/^background = .*/background = $BACKGROUND/
    s/^foreground = .*/foreground = $FOREGROUND/
    s/^regular0 = .*/regular0 = $TERM0/
    s/^regular1 = .*/regular1 = $TERM1/
    s/^regular2 = .*/regular2 = $TERM2/
    s/^regular3 = .*/regular3 = $TERM3/
    s/^regular4 = .*/regular4 = $TERM4/
    s/^regular5 = .*/regular5 = $TERM5/
    s/^regular6 = .*/regular6 = $TERM6/
    s/^regular7 = .*/regular7 = $TERM7/
    s/^bright0 = .*/bright0 = $TERM8/
    s/^bright1 = .*/bright1 = $TERM9/
    s/^bright2 = .*/bright2 = $TERM10/
    s/^bright3 = .*/bright3 = $TERM11/
    s/^bright4 = .*/bright4 = $TERM12/
    s/^bright5 = .*/bright5 = $TERM13/
    s/^bright6 = .*/bright6 = $TERM14/
    s/^bright7 = .*/bright7 = $TERM15/
}" "$FOOT_CONFIG"

echo "✓ Terminal colors updated (restart foot manually to see changes)"